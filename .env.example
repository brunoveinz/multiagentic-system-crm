# =========================================================================
# Plantilla de variables de entorno. Copiar a `.env` y completar.
# NUNCA commitear `.env` (está en .gitignore). Solo este ejemplo se versiona.
# =========================================================================

# --- Django ---
# Generar una nueva: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-larga-y-secreta
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api
# Orígenes del frontend permitidos para CORS (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_DB=ventas
POSTGRES_USER=ventas
POSTGRES_PASSWORD=ventas
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (broker de Celery + caché) ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant (BBDD vectorial) ---
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=   # opcional en local; requerido en prod

# --- OpenAI (chat + embeddings) — se usa desde la Fase 4 ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Google OAuth (Gmail, scope gmail.send) — se usa desde la Fase 5 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/accounts/gmail/callback/

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
