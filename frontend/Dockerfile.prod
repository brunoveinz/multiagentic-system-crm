# Imagen de producción del frontend: build + next start.
FROM node:22-slim

WORKDIR /app

# Same-origin en prod: el front llama a /api y Next lo proxea al backend.
# (NEXT_PUBLIC_* se inyecta en build, por eso va acá.)
ENV NEXT_PUBLIC_API_BASE_URL=""
ENV NODE_ENV=production

COPY package.json ./
RUN npm install

COPY . .
RUN npm run build

EXPOSE 3000
CMD ["npm", "run", "start"]
