# Imagen de producción del frontend: build + next start.
FROM node:22-slim

WORKDIR /app

# Same-origin en prod: el front llama a /api y Next lo proxea al backend.
# (NEXT_PUBLIC_* se inyecta en build, por eso va acá.)
ENV NEXT_PUBLIC_API_BASE_URL=""
ENV NODE_ENV=production

# El destino del proxy /api se hornea durante `next build`, así que tiene que
# estar disponible ACÁ y no solo en el `environment:` del compose (runtime).
ARG API_PROXY_TARGET=http://ventas-api:8000
ENV API_PROXY_TARGET=$API_PROXY_TARGET

COPY package.json ./
RUN npm install

COPY . .
RUN npm run build

EXPOSE 3000
CMD ["npm", "run", "start"]
