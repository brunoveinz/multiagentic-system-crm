# =========================================================================
# Variables de PRODUCCIÓN (Dokploy). Cargá estos valores en el panel de
# Dokploy (Environment), NO en el repo. Esto es solo un ejemplo con placeholders.
# =========================================================================

# --- Django ---
# Generar: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=GENERAR-UNA-CLAVE-LARGA-Y-SECRETA
DJANGO_ALLOWED_HOSTS=api,localhost,127.0.0.1,ventas.brunoveinz.com
CSRF_TRUSTED_ORIGINS=https://ventas.brunoveinz.com
CORS_ALLOWED_ORIGINS=https://ventas.brunoveinz.com
FRONTEND_URL=https://ventas.brunoveinz.com

# --- PostgreSQL ---
POSTGRES_DB=ventas
POSTGRES_USER=ventas
POSTGRES_PASSWORD=PONER-UNA-CLAVE-FUERTE

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
